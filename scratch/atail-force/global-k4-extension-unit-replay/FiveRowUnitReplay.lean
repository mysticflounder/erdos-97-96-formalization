/-- The independently verified sparse rational certificate. -/
def fiveRowCertificate : Certificate :=
  { generators := activeGenerators
    coefficients := activeCoefficients }

/-- Pure-kernel validation of the exact rational identity. -/
theorem fiveRowCertificate_valid :
    checkCertificate fiveRowCertificate = true := by
  decide

/-- Assignment order used by the certificate:
`0=x2x, 1=x2y, 2=x3x, 3=x3y, 4=x4x, 5=x4y, 6=x6x, 7=x6y, 8=x7x, 9=x7y, 10=x8x, 11=x8y, 12=x9x, 13=x9y, 14=x12x, 15=x12y, 16=x13x, 17=x13y`. -/
def normalizedAssignment (x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y : ℝ) : Nat → ℝ
  | 0 => x2x
  | 1 => x2y
  | 2 => x3x
  | 3 => x3y
  | 4 => x4x
  | 5 => x4y
  | 6 => x6x
  | 7 => x6y
  | 8 => x7x
  | 9 => x7y
  | 10 => x8x
  | 11 => x8y
  | 12 => x9x
  | 13 => x9y
  | 14 => x12x
  | 15 => x12y
  | 16 => x13x
  | 17 => x13y
  | _ => 0

/-- The sixteen pinned normalized squared-distance differences imply that
every active certificate generator evaluates to zero. -/
theorem activeGeneratorZeros
    (x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y : ℝ)
    (h00 : -x2x^2-x2y^2+1 = 0) -- ROW_0_1_2
    (h01 : -x6x^2-x6y^2+1 = 0) -- ROW_0_1_6
    (h02 : -x7x^2-x7y^2+1 = 0) -- ROW_0_1_7
    (h03 : -x8x^2-x8y^2+1 = 0) -- ROW_0_1_8
    (h04 : 2*x6x*x8x-2*x6x+2*x6y*x8y-x8x^2-x8y^2+1 = 0) -- ROW_6_1_8
    (h05 : 2*x6x*x12x-2*x6x+2*x6y*x12y-x12x^2-x12y^2+1 = 0) -- ROW_6_1_12
    (h06 : 2*x6x*x13x-2*x6x+2*x6y*x13y-x13x^2-x13y^2+1 = 0) -- ROW_6_1_13
    (h07 : -x4x^2+2*x4x*x8x-x4y^2+2*x4y*x8y = 0) -- ROW_8_0_4
    (h08 : -x7x^2+2*x7x*x8x-x7y^2+2*x7y*x8y = 0) -- ROW_8_0_7
    (h09 : 2*x8x*x13x+2*x8y*x13y-x13x^2-x13y^2 = 0) -- ROW_8_0_13
    (h10 : -x3x^2+2*x3x*x12x-x3y^2+2*x3y*x12y = 0) -- ROW_12_0_3
    (h11 : -x7x^2+2*x7x*x12x-x7y^2+2*x7y*x12y = 0) -- ROW_12_0_7
    (h12 : -x8x^2+2*x8x*x12x-x8y^2+2*x8y*x12y = 0) -- ROW_12_0_8
    (h13 : -x3x^2+2*x3x*x13x-x3y^2+2*x3y*x13y-2*x13x+1 = 0) -- ROW_13_1_3
    (h14 : -x9x^2+2*x9x*x13x-x9y^2+2*x9y*x13y-2*x13x+1 = 0) -- ROW_13_1_9
    (h15 : -x12x^2+2*x12x*x13x-x12y^2+2*x12y*x13y-2*x13x+1 = 0) -- ROW_13_1_12
    : ∀ g ∈ activeGenerators,
        evalPoly (normalizedAssignment x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y) g = 0 := by
  intro g hg
  simp only [activeGenerators, List.mem_cons, List.not_mem_nil, or_false] at hg
  rcases hg with rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl
  · -- ROW_0_1_6
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h01]
  · -- ROW_0_1_7
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h02]
  · -- ROW_0_1_8
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h03]
  · -- ROW_6_1_8
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h04]
  · -- ROW_6_1_12
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h05]
  · -- ROW_6_1_13
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h06]
  · -- ROW_8_0_7
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h08]
  · -- ROW_8_0_13
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h09]
  · -- ROW_12_0_7
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h11]
  · -- ROW_12_0_8
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h12]
  · -- ROW_13_1_12
    norm_num [evalPoly, evalTerm, evalMonom, normalizedAssignment] <;>
      nlinarith [h15]

/-- Exact normalized scalar terminal for the retained O,D,E,I,F rows. -/
theorem false_of_allSixteenNormalizedFiveRowEqualities
    (x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y : ℝ)
    (h00 : -x2x^2-x2y^2+1 = 0) -- ROW_0_1_2
    (h01 : -x6x^2-x6y^2+1 = 0) -- ROW_0_1_6
    (h02 : -x7x^2-x7y^2+1 = 0) -- ROW_0_1_7
    (h03 : -x8x^2-x8y^2+1 = 0) -- ROW_0_1_8
    (h04 : 2*x6x*x8x-2*x6x+2*x6y*x8y-x8x^2-x8y^2+1 = 0) -- ROW_6_1_8
    (h05 : 2*x6x*x12x-2*x6x+2*x6y*x12y-x12x^2-x12y^2+1 = 0) -- ROW_6_1_12
    (h06 : 2*x6x*x13x-2*x6x+2*x6y*x13y-x13x^2-x13y^2+1 = 0) -- ROW_6_1_13
    (h07 : -x4x^2+2*x4x*x8x-x4y^2+2*x4y*x8y = 0) -- ROW_8_0_4
    (h08 : -x7x^2+2*x7x*x8x-x7y^2+2*x7y*x8y = 0) -- ROW_8_0_7
    (h09 : 2*x8x*x13x+2*x8y*x13y-x13x^2-x13y^2 = 0) -- ROW_8_0_13
    (h10 : -x3x^2+2*x3x*x12x-x3y^2+2*x3y*x12y = 0) -- ROW_12_0_3
    (h11 : -x7x^2+2*x7x*x12x-x7y^2+2*x7y*x12y = 0) -- ROW_12_0_7
    (h12 : -x8x^2+2*x8x*x12x-x8y^2+2*x8y*x12y = 0) -- ROW_12_0_8
    (h13 : -x3x^2+2*x3x*x13x-x3y^2+2*x3y*x13y-2*x13x+1 = 0) -- ROW_13_1_3
    (h14 : -x9x^2+2*x9x*x13x-x9y^2+2*x9y*x13y-2*x13x+1 = 0) -- ROW_13_1_9
    (h15 : -x12x^2+2*x12x*x13x-x12y^2+2*x12y*x13y-2*x13x+1 = 0) -- ROW_13_1_12
    : False := by
  exact false_of_checkCertificate
    (normalizedAssignment x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y)
    fiveRowCertificate
    fiveRowCertificate_valid
    (activeGeneratorZeros x2x x2y x3x x3y x4x x4y x6x x6y x7x x7y x8x x8y x9x x9y x12x x12y x13x x13y
      h00 h01 h02 h03 h04 h05 h06 h07 h08 h09 h10 h11 h12 h13 h14 h15)

#print axioms fiveRowCertificate_valid
#print axioms false_of_allSixteenNormalizedFiveRowEqualities

