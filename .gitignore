# Lake build artifacts — oleans, generated C/IR, *.setup.json, *.c.hash,
# the build lock, and the fetched dependency packages all live under .lake/.
# Unanchored so it matches lean/.lake/ and any nested .lake/ dir.
.lake/
build/
*.olean
*.ilean

# Build-only convenience symlink to a pre-fetched packages dir (never commit).
/lean/.lake_packages_src

# Editor / OS
.DS_Store
*.swp

# proof-blueprint DB (build artifact; intent/ is the checked-in record)
data/

# tooling junk
.nthdegree/
scripts/__pycache__/
__pycache__/
*.pyc

# Local heavy proof-search and generated certificate artifacts.
/certificates/surplus/relaxed_split/
/scratch/census-12-gate/

# Local solver output from scratch probes.
/scratch/q3-two-center/runs/
/scratch/q3-two-center/smoke_results.json
.venv/

# census-554 run artifacts: banking intermediates (contents live in
# bank.jsonl + certs/), untracked run logs, writer lock, blueprint DB.
/scratch/census-554/frontier_*.json
/scratch/census-554/audit_pat0*.log
/scratch/census-554/bank_frontier.log
/scratch/census-554/cover_probe.log
/scratch/census-554/frontier_*.log
/scratch/census-554/intracap.log
/scratch/census-554/motif_transfer.log
/scratch/census-554/retry_certify*.log
/scratch/census-554/bank.jsonl.lock
/scratch/census-554/retry_certified_pending.json
.blueprint.db
