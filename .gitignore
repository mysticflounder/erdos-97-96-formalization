# Lake build artifacts — oleans, generated C/IR, *.setup.json, *.c.hash,
# the build lock, and the fetched dependency packages all live under .lake/.
# Unanchored so it matches lean/.lake/ and any nested .lake/ dir.
.lake/
build/
*.olean
*.ilean

# Build-only convenience symlink to a pre-fetched packages dir (never commit).
/lean/.lake_packages_src

# Editor / OS
.DS_Store
*.swp

# proof-blueprint DB (build artifact; intent/ is the checked-in record)
data/

# tooling junk
.nthdegree/
scripts/__pycache__/
__pycache__/
*.pyc

# Local heavy proof-search and generated certificate artifacts.
/certificates/surplus/relaxed_split/
/scratch/census-12-gate/

# Local solver output from scratch probes.
/scratch/q3-two-center/runs/
/scratch/q3-two-center/smoke_results.json
.venv/

# census-554 run artifacts: banking intermediates (contents live in
# bank.jsonl + certs/), untracked run logs, writer lock, blueprint DB.
/scratch/census-554/frontier_*.json
/scratch/census-554/audit_pat0*.log
/scratch/census-554/bank_frontier.log
/scratch/census-554/cover_probe.log
/scratch/census-554/frontier_*.log
/scratch/census-554/intracap.log
/scratch/census-554/motif_transfer.log
/scratch/census-554/retry_certify*.log
/scratch/census-554/oracle13_transition_*.log
/scratch/census-554/bank.jsonl.lock
/scratch/census-554/retry_certified_pending.json
/scratch/census-554/retry_certified_pending.jsonl
/scratch/census-554/retry_certified_pending.d/
/scratch/census-554/certification_backlog.d/
/scratch/census-554/exact_cert_outcomes.sqlite3*
.blueprint.db
/census/multi_center/frontier_cache/
/census/multi_center/*.log
/scratch/census-554/driver.lock

# census-554 probe run artifacts (multi-GB solver output; the probe
# scripts and their summaries are what gets committed).
/scratch/census-554/separation_probe_runs/
/scratch/census-554/transition_snapshots/
/scratch/census-554/frontier_analysis_runs/
/scratch/census-554/cube_prefetch_runs/
/scratch/census-554/frontier_mining_runs/
/scratch/census-554/mine_prefetch_runs/
/scratch/census-554/separation_experiments/

# queue worker runtime state
/scratch/census-554/worker/worker.log
/scratch/census-554/worker/worker.pid
/scratch/census-554/worker/supervisor.pid
/scratch/census-554/worker/worker-exits.log

# Disposable proof-blueprint snippets and local gate logs.
/lean/_pb_snippet_*.lean
/scratch/erase-m1-gate-run/

# Local theorem experiments; promote finished sources into lean/ explicitly.
/tmp/

# Singular REPL history
.singularhistory

# ATAIL bank-clean / FA-UNIQ generated certificates over GitHub's 100 MB
# hard limit. Deterministically replayable from the pinned scripts; digests
# recorded in scratch/atail-force/unique-row-producer/REPORT.md and the
# bank-clean checkpoints.
/scratch/atail-force/bank-clean-lean-certificate/microsharded/BankClean15MicroshardedCertificate.lean
/scratch/atail-force/bank-clean-lean-certificate/staged/BankClean15StagedCertificate.lean
/scratch/atail-force/unique-row-producer/collision_core_offset3_654_certificate.json
/scratch/atail-force/unique-row-producer/collision_core_offset3_pair_0_10_654_certificate.json
/scratch/atail-force/unique-row-producer/source_indexed_unit_core_654_10_gauge_1_9_singular_lift.json
/scratch/atail-force/unique-row-producer/source_indexed_unit_core_654_47_alt_gauge_4_5_singular_reverse_1800s.json
/scratch/atail-force/unique-row-producer/source_indexed_unit_core_654_59_gauge_2_11_singular_reverse_1800s.json
/scratch/atail-force/unique-row-producer/unit_core_source_indexed_654_10_certificate.json
/scratch/atail-force/unique-row-producer/unit_core_source_indexed_654_10_scalar_certificate.lean
/scratch/atail-force/unique-row-producer/unit_core_source_indexed_654_47_alt_certificate.json
/scratch/atail-force/unique-row-producer/unit_core_source_indexed_654_47_alt_scalar_certificate.lean

# unique-row-producer generated certificate/verification payloads (tens of
# MB each, hundreds of MB total). Replayable from the committed generator
# scripts; digests live in that dir's REPORT.md. Scripts, REPORT.md, and
# small .md/.py summaries stay tracked.
/scratch/atail-force/unique-row-producer/*_certificate.json
/scratch/atail-force/unique-row-producer/*_certificate.lean
/scratch/atail-force/unique-row-producer/*_verification.json
/scratch/atail-force/unique-row-producer/*_singular_lift.json
/scratch/atail-force/unique-row-producer/*_singular_reverse_*.json
/scratch/atail-force/unique-row-producer/source_indexed_unit_core_*.json

