import Erdos9796Proof.P97.Census554.MotifTransfer
import Erdos9796Proof.P97.Dumitrescu.L1
import Erdos9796Proof.P97.N4d.SmallSReductions
import Erdos9796Proof.P97.U5GlobalIncidenceKernels

/-!
# Equality-closure cores for Census-554 patterns

This file separates the reusable geometric part of equality-only Census-554
patterns from their finite discovery.  A realized pattern makes every row's
center-to-mask distances equal.  `EdgeClosure` records the reflexive,
symmetric, transitive closure of those equalities, including reversal of a
distance edge.  Two finite witnesses then route that closure to existing plane
geometry kernels:

* `DuplicateCenterCore` contradicts uniqueness of the circumcenter of three
  distinct points; and
* `PerpBisectorCore` contradicts the convex-independent perpendicular-bisector
  apex bound;
* `EqualK4Core` contradicts four pairwise-equidistant planar points.
* `ExactOffCircleCore` contradicts exactness when equality closure forces an
  excluded label onto a row circle.

The theorem layer is ambient-label-type independent.  It neither validates a
finite miner witness nor asserts coverage of the Census-554 bank.
-/

open scoped EuclideanGeometry

namespace Problem97
namespace Census554
namespace EqualityCore

/-- A finite equidistance pattern on an arbitrary label type. -/
abbrev RowPattern (α : Type*) := α → Finset α

/-- An oriented distance edge.  `EdgeClosure.flip` identifies its two
orientations, so no order on the label type is required. -/
abbrev Edge (α : Type*) := α × α

/-- The geometric length attached to an oriented distance edge. -/
noncomputable def edgeDist {α : Type*} (pointOf : α → ℝ²) : Edge α → ℝ
  | (a, b) => dist (pointOf a) (pointOf b)

/-- An injective plane realization of a row pattern, without the Census-554
gauge. -/
structure Realizes {α : Type*} (P : RowPattern α) (pointOf : α → ℝ²) : Prop where
  equidist : ∀ c, ∀ a ∈ P c, ∀ b ∈ P c,
    dist (pointOf c) (pointOf a) = dist (pointOf c) (pointOf b)
  injective : Function.Injective pointOf

/-- Reflection across the first coordinate axis. -/
def reflectXAxis (p : ℝ²) : ℝ² :=
  !₂[p 0, -p 1]

/-- Axis reflection is injective. -/
theorem reflectXAxis_injective : Function.Injective reflectXAxis := by
  intro p q h
  ext i
  fin_cases i
  · have h0 := congrArg (fun z : ℝ² => z 0) h
    simpa [reflectXAxis] using h0
  · have h1 := congrArg (fun z : ℝ² => z 1) h
    simpa [reflectXAxis] using congrArg Neg.neg h1

private theorem dist_sq_coords_reflection (u v : ℝ²) :
    dist u v ^ 2 = (u 0 - v 0) ^ 2 + (u 1 - v 1) ^ 2 := by
  rw [dist_eq_norm, EuclideanSpace.norm_sq_eq]
  simp [Fin.sum_univ_two, sq_abs, Real.norm_eq_abs, PiLp.sub_apply]

/-- Axis reflection preserves Euclidean distance. -/
theorem dist_reflectXAxis (p q : ℝ²) :
    dist (reflectXAxis p) (reflectXAxis q) = dist p q := by
  have hsq :
      dist (reflectXAxis p) (reflectXAxis q) ^ 2 = dist p q ^ 2 := by
    rw [dist_sq_coords_reflection, dist_sq_coords_reflection]
    simp [reflectXAxis]
    ring
  nlinarith [dist_nonneg (x := reflectXAxis p) (y := reflectXAxis q),
    dist_nonneg (x := p) (y := q)]

/-- Axis reflection reverses signed orientation. -/
theorem signedArea2_reflectXAxis (a b c : ℝ²) :
    signedArea2 (reflectXAxis a) (reflectXAxis b) (reflectXAxis c) =
      -signedArea2 a b c := by
  simp [reflectXAxis, signedArea2]
  ring

/-- Reflecting a geometric interpretation preserves row realization. -/
theorem Realizes.reflectXAxis
    {α : Type*} {P : RowPattern α} {pointOf : α → ℝ²}
    (hreal : Realizes P pointOf) :
    Realizes P (fun a => reflectXAxis (pointOf a)) := by
  refine ⟨?_, fun _ _ h => hreal.injective (reflectXAxis_injective h)⟩
  intro center a ha b hb
  rw [dist_reflectXAxis, dist_reflectXAxis]
  exact hreal.equidist center a ha b hb

/-- The finite equality closure generated by equal distances in each pattern
row, together with reversal of an oriented distance edge. -/
inductive EdgeClosure {α : Type*} (P : RowPattern α) : Edge α → Edge α → Prop
  | row (c a b : α) (ha : a ∈ P c) (hb : b ∈ P c) :
      EdgeClosure P (c, a) (c, b)
  | flip (a b : α) : EdgeClosure P (a, b) (b, a)
  | refl (e : Edge α) : EdgeClosure P e e
  | symm {e f : Edge α} : EdgeClosure P e f → EdgeClosure P f e
  | trans {e f g : Edge α} : EdgeClosure P e f → EdgeClosure P f g →
      EdgeClosure P e g

/-- Every equality generated by `EdgeClosure` is valid in a geometric
realization of the pattern. -/
theorem EdgeClosure.sound {α : Type*} {P : RowPattern α} {pointOf : α → ℝ²}
    (hreal : Realizes P pointOf) {e f : Edge α}
    (hclosure : EdgeClosure P e f) :
    edgeDist pointOf e = edgeDist pointOf f := by
  induction hclosure with
  | row c a b ha hb =>
      simpa [edgeDist] using hreal.equidist c a ha b hb
  | flip a b =>
      simpa [edgeDist] using (dist_comm (pointOf a) (pointOf b))
  | refl e => rfl
  | symm _ ih => exact ih.symm
  | trans _ _ ih₁ ih₂ => exact ih₁.trans ih₂

/-- Exactness of one row: every label outside its support has a different
distance from the row center than every support label. -/
def ExactAt {α : Type*} (P : RowPattern α) (pointOf : α → ℝ²) (c : α) : Prop :=
  ∀ a ∈ P c, ∀ z, z ∉ P c →
    dist (pointOf c) (pointOf z) ≠ dist (pointOf c) (pointOf a)

/-- A closure witness forcing an excluded label onto the circle of an exact
row. -/
structure ExactOffCircleCore {α : Type*} (P : RowPattern α) where
  c : α
  a : α
  z : α
  ha : a ∈ P c
  hz : z ∉ P c
  hacz : EdgeClosure P (c, a) (c, z)

/-- An equality closure cannot force an excluded label onto an exact row's
circle. -/
theorem false_of_exactAt_of_exactOffCircleCore
    {α : Type*} {P : RowPattern α} {pointOf : α → ℝ²}
    (hreal : Realizes P pointOf) (core : ExactOffCircleCore P)
    (hexact : ExactAt P pointOf core.c) : False := by
  have heq :
      dist (pointOf core.c) (pointOf core.a) =
        dist (pointOf core.c) (pointOf core.z) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hacz
  exact (hexact core.a core.ha core.z core.hz) heq.symm

/-- A closure witness saying that two distinct centers are each equidistant
from the same three pairwise-distinct labels. -/
structure DuplicateCenterCore {α : Type*} (P : RowPattern α) where
  p : α
  q : α
  r : α
  a : α
  b : α
  hpq : p ≠ q
  hpr : p ≠ r
  hqr : q ≠ r
  hab : a ≠ b
  ap_aq : EdgeClosure P (a, p) (a, q)
  ap_ar : EdgeClosure P (a, p) (a, r)
  bp_bq : EdgeClosure P (b, p) (b, q)
  bp_br : EdgeClosure P (b, p) (b, r)

/-- A duplicate-center equality core has no injective planar realization. -/
theorem not_realizes_of_duplicateCenterCore {α : Type*} {P : RowPattern α}
    (core : DuplicateCenterCore P) :
    ¬ ∃ pointOf : α → ℝ², Realizes P pointOf := by
  rintro ⟨pointOf, hreal⟩
  have hpq : pointOf core.p ≠ pointOf core.q := by
    intro h
    exact core.hpq (hreal.injective h)
  have hpr : pointOf core.p ≠ pointOf core.r := by
    intro h
    exact core.hpr (hreal.injective h)
  have hqr : pointOf core.q ≠ pointOf core.r := by
    intro h
    exact core.hqr (hreal.injective h)
  have hab : pointOf core.a ≠ pointOf core.b := by
    intro h
    exact core.hab (hreal.injective h)
  have hap_aq :
      dist (pointOf core.a) (pointOf core.p) =
        dist (pointOf core.a) (pointOf core.q) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.ap_aq
  have hap_ar :
      dist (pointOf core.a) (pointOf core.p) =
        dist (pointOf core.a) (pointOf core.r) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.ap_ar
  have hbp_bq :
      dist (pointOf core.b) (pointOf core.p) =
        dist (pointOf core.b) (pointOf core.q) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.bp_bq
  have hbp_br :
      dist (pointOf core.b) (pointOf core.p) =
        dist (pointOf core.b) (pointOf core.r) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.bp_br
  exact not_dist_eq_three_of_ne
    (pointOf core.p) (pointOf core.q) (pointOf core.r)
    (pointOf core.a) (pointOf core.b) hpq hpr hqr
    hap_aq hap_ar hbp_bq hbp_br hab

/-- A closure witness forcing three distinct labels onto the perpendicular
bisector of the same two distinct foci. -/
structure PerpBisectorCore {α : Type*} (P : RowPattern α) where
  a : α
  b : α
  p : α
  q : α
  r : α
  hab : a ≠ b
  hpq : p ≠ q
  hpr : p ≠ r
  hqr : q ≠ r
  pa_pb : EdgeClosure P (p, a) (p, b)
  qa_qb : EdgeClosure P (q, a) (q, b)
  ra_rb : EdgeClosure P (r, a) (r, b)

/-- Three equality-forced perpendicular-bisector labels contradict convex
independence of the realized carrier. -/
theorem false_of_convexIndep_of_perpBisectorCore
    {α : Type*} {P : RowPattern α} {pointOf : α → ℝ²} {A : Finset ℝ²}
    (hreal : Realizes P pointOf) (hconv : ConvexIndep A)
    (hmem : ∀ x, pointOf x ∈ A) (core : PerpBisectorCore P) : False := by
  have hab : pointOf core.a ≠ pointOf core.b := by
    intro h
    exact core.hab (hreal.injective h)
  have hpq : pointOf core.p ≠ pointOf core.q := by
    intro h
    exact core.hpq (hreal.injective h)
  have hpr : pointOf core.p ≠ pointOf core.r := by
    intro h
    exact core.hpr (hreal.injective h)
  have hqr : pointOf core.q ≠ pointOf core.r := by
    intro h
    exact core.hqr (hreal.injective h)
  have hpeq :
      dist (pointOf core.p) (pointOf core.a) =
        dist (pointOf core.p) (pointOf core.b) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.pa_pb
  have hqeq :
      dist (pointOf core.q) (pointOf core.a) =
        dist (pointOf core.q) (pointOf core.b) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.qa_qb
  have hreq :
      dist (pointOf core.r) (pointOf core.a) =
        dist (pointOf core.r) (pointOf core.b) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.ra_rb
  have hp_mem :
      pointOf core.p ∈
        A.filter (fun x => dist x (pointOf core.a) = dist x (pointOf core.b)) :=
    Finset.mem_filter.mpr ⟨hmem core.p, hpeq⟩
  have hq_mem :
      pointOf core.q ∈
        A.filter (fun x => dist x (pointOf core.a) = dist x (pointOf core.b)) :=
    Finset.mem_filter.mpr ⟨hmem core.q, hqeq⟩
  have hr_mem :
      pointOf core.r ∈
        A.filter (fun x => dist x (pointOf core.a) = dist x (pointOf core.b)) :=
    Finset.mem_filter.mpr ⟨hmem core.r, hreq⟩
  have hlarge :
      2 < (A.filter
        (fun x => dist x (pointOf core.a) = dist x (pointOf core.b))).card := by
    rw [Finset.two_lt_card]
    exact ⟨pointOf core.p, hp_mem, pointOf core.q, hq_mem,
      pointOf core.r, hr_mem, hpq, hpr, hqr⟩
  have hbound := Dumitrescu.perpBisector_apex_bound hconv
    (hmem core.a) (hmem core.b) hab
  exact (not_lt_of_ge hbound) hlarge

/-- A closure witness saying that the six distances among four labels are all
equal to the first edge's positive length. -/
structure EqualK4Core {α : Type*} (P : RowPattern α) where
  p : α
  t₁ : α
  t₂ : α
  t₃ : α
  hpt₁ : p ≠ t₁
  hp₁p₂ : EdgeClosure P (p, t₁) (p, t₂)
  hp₁p₃ : EdgeClosure P (p, t₁) (p, t₃)
  hp₁₁₂ : EdgeClosure P (p, t₁) (t₁, t₂)
  hp₁₁₃ : EdgeClosure P (p, t₁) (t₁, t₃)
  hp₁₂₃ : EdgeClosure P (p, t₁) (t₂, t₃)

/-- An equal-`K4` equality core has no injective planar realization. -/
theorem not_realizes_of_equalK4Core {α : Type*} {P : RowPattern α}
    (core : EqualK4Core P) :
    ¬ ∃ pointOf : α → ℝ², Realizes P pointOf := by
  rintro ⟨pointOf, hreal⟩
  have hpt₁ : pointOf core.p ≠ pointOf core.t₁ := by
    intro h
    exact core.hpt₁ (hreal.injective h)
  have hp₁p₂ :
      dist (pointOf core.p) (pointOf core.t₁) =
        dist (pointOf core.p) (pointOf core.t₂) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hp₁p₂
  have hp₁p₃ :
      dist (pointOf core.p) (pointOf core.t₁) =
        dist (pointOf core.p) (pointOf core.t₃) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hp₁p₃
  have hp₁₁₂ :
      dist (pointOf core.p) (pointOf core.t₁) =
        dist (pointOf core.t₁) (pointOf core.t₂) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hp₁₁₂
  have hp₁₁₃ :
      dist (pointOf core.p) (pointOf core.t₁) =
        dist (pointOf core.t₁) (pointOf core.t₃) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hp₁₁₃
  have hp₁₂₃ :
      dist (pointOf core.p) (pointOf core.t₁) =
        dist (pointOf core.t₂) (pointOf core.t₃) := by
    simpa [edgeDist] using EdgeClosure.sound hreal core.hp₁₂₃
  exact u5_unit_triangle_on_p_circle_incompatibility
    (p := pointOf core.p) (t1 := pointOf core.t₁)
    (t2 := pointOf core.t₂) (t3 := pointOf core.t₃)
    (r := dist (pointOf core.p) (pointOf core.t₁))
    (dist_pos.mpr hpt₁) rfl hp₁p₂.symm hp₁p₃.symm hp₁₁₂.symm hp₁₁₃.symm
      hp₁₂₃.symm

/-- Forget the Census-554 gauge while retaining the exact realization data
needed by the generic equality-core theorems. -/
def toRealizes {P : Pattern} {y : Fin 11 → ℝ²}
    (hreal : IsGaugedRealization P y) : Realizes P y where
  equidist := hreal.equidist
  injective := hreal.injective

/-- A duplicate-center equality core proves a Census-554 pattern dead. -/
theorem isDead_of_duplicateCenterCore {P : Pattern}
    (core : DuplicateCenterCore P) : IsDead P := by
  rintro ⟨pointOf, hreal⟩
  exact not_realizes_of_duplicateCenterCore core
    ⟨pointOf, toRealizes hreal⟩

/-- An equal-`K4` equality core proves a Census-554 pattern dead. -/
theorem isDead_of_equalK4Core {P : Pattern}
    (core : EqualK4Core P) : IsDead P := by
  rintro ⟨pointOf, hreal⟩
  exact not_realizes_of_equalK4Core core ⟨pointOf, toRealizes hreal⟩

end EqualityCore
end Census554
