import Erdos9796Proof.P97.Census554.EqualityCore
import Erdos9796Proof.P97.SurplusCOMPGBankSep

/-!
# Cyclic-separation cores for Census-554 patterns

This file turns equality closure into an order obstruction.  If two distinct
centers are equidistant from the same two distinct labels, the two labels must
alternate across the centers in every injective CCW convex enumeration.  The
generic theorem is independent of the Census-554 label type.

The second part records the finite card-11 macro-order surface
`U, O2, V, S, W, O1`.  Internal orders within the `O2`, `S`, and `O1` blocks
are unrestricted.  A row is rejected when every permutation on that surface
violates a separation core generated by its equality closure.

This module does not prove that a geometric card-11 cap labeling has one of
these macro orders.  That statement requires an adapter from the global CCW
boundary enumeration and cap-block data to the canonical Census-554 labels.
-/

open scoped EuclideanGeometry

namespace Problem97
namespace Census554
namespace SeparationCore

open EqualityCore

/-- Equality-closure data saying that two centers have the same two labels on
their respective circles.  The inequalities are exactly those needed by
`SurplusCOMPGBank.btw_sep`; `secondPoint` is distinguished only because that
theorem uses it for the endpoint exclusions. -/
structure SharedPairSeparationCore {α : Type*} (P : RowPattern α) where
  firstCenter : α
  secondCenter : α
  firstPoint : α
  secondPoint : α
  centers_ne : firstCenter ≠ secondCenter
  secondPoint_ne_firstCenter : secondPoint ≠ firstCenter
  secondPoint_ne_secondCenter : secondPoint ≠ secondCenter
  points_ne : firstPoint ≠ secondPoint
  firstCenter_eq :
    EdgeClosure P (firstCenter, firstPoint) (firstCenter, secondPoint)
  secondCenter_eq :
    EdgeClosure P (secondCenter, firstPoint) (secondCenter, secondPoint)

/-- The cyclic alternation required by a shared-pair separation core in a
chosen linear cut of the boundary order. -/
def SharedPairSeparationCore.SatisfiedBy
    {α : Type*} {P : RowPattern α} (core : SharedPairSeparationCore P)
    {n : ℕ} (indexOf : α → Fin n) : Prop :=
  SurplusCOMPGBank.btw
      (indexOf core.firstCenter) (indexOf core.secondCenter)
      (indexOf core.firstPoint) ↔
    ¬ SurplusCOMPGBank.btw
      (indexOf core.firstCenter) (indexOf core.secondCenter)
      (indexOf core.secondPoint)

/-- A realized equality core satisfies cyclic separation in every compatible
injective CCW convex enumeration. -/
theorem SharedPairSeparationCore.satisfiedBy_of_realizes_ccw
    {α : Type*} {P : RowPattern α} {pointOf : α → ℝ²}
    (core : SharedPairSeparationCore P) (hreal : Realizes P pointOf)
    {n : ℕ} (boundary : Fin n → ℝ²) (indexOf : α → Fin n)
    (hccw : EuclideanGeometry.IsCcwConvexPolygon boundary)
    (hboundary : Function.Injective boundary)
    (hindex : Function.Injective indexOf)
    (hpoint : ∀ label, boundary (indexOf label) = pointOf label) :
    core.SatisfiedBy indexOf := by
  have hfirst :
      dist (boundary (indexOf core.firstPoint))
          (boundary (indexOf core.firstCenter)) =
        dist (boundary (indexOf core.secondPoint))
          (boundary (indexOf core.firstCenter)) := by
    simpa only [hpoint, edgeDist, dist_comm] using
      EdgeClosure.sound hreal core.firstCenter_eq
  have hsecond :
      dist (boundary (indexOf core.firstPoint))
          (boundary (indexOf core.secondCenter)) =
        dist (boundary (indexOf core.secondPoint))
          (boundary (indexOf core.secondCenter)) := by
    simpa only [hpoint, edgeDist, dist_comm] using
      EdgeClosure.sound hreal core.secondCenter_eq
  apply SurplusCOMPGBank.btw_sep hccw hboundary
  · exact hindex.ne core.centers_ne
  · exact hindex.ne core.secondPoint_ne_firstCenter
  · exact hindex.ne core.secondPoint_ne_secondCenter
  · exact hfirst
  · exact hsecond
  · exact hboundary.ne (hindex.ne core.points_ne)

/-- The right-nested sum of the six blocks in the card-11 cut
`U, O2, V, S, W, O1`. -/
abbrev Card11MacroPart :=
  Fin 1 ⊕ (Fin 2 ⊕ (Fin 1 ⊕ (Fin 3 ⊕ (Fin 1 ⊕ Fin 3))))

/-- Split canonical Census-554 labels into the macro blocks
`U, O2, V, S, W, O1`. -/
def card11MacroSplit : Fin 11 ≃ Card11MacroPart where
  toFun
    | ⟨0, _⟩ => Sum.inl 0
    | ⟨1, _⟩ => Sum.inr (Sum.inr (Sum.inl 0))
    | ⟨2, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inl 0))))
    | ⟨3, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inl 0)))
    | ⟨4, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inl 1)))
    | ⟨5, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inl 2)))
    | ⟨6, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inr 0))))
    | ⟨7, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inr 1))))
    | ⟨8, _⟩ => Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inr 2))))
    | ⟨9, _⟩ => Sum.inr (Sum.inl 0)
    | ⟨10, _⟩ => Sum.inr (Sum.inl 1)
    | ⟨n + 11, h⟩ => by omega
  invFun
    | Sum.inl _ => 0
    | Sum.inr (Sum.inl i) => ⟨9 + i, by omega⟩
    | Sum.inr (Sum.inr (Sum.inl _)) => 1
    | Sum.inr (Sum.inr (Sum.inr (Sum.inl i))) => ⟨3 + i, by omega⟩
    | Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inl _)))) => 2
    | Sum.inr (Sum.inr (Sum.inr (Sum.inr (Sum.inr i)))) => ⟨6 + i, by omega⟩
  left_inv := by
    intro label
    fin_cases label <;> rfl
  right_inv := by
    intro part
    rcases part with u | tail
    · fin_cases u
      rfl
    · rcases tail with o2 | tail
      · fin_cases o2 <;> rfl
      · rcases tail with v | tail
        · fin_cases v
          rfl
        · rcases tail with s | tail
          · fin_cases s <;> rfl
          · rcases tail with w | o1
            · fin_cases w
              rfl
            · fin_cases o1 <;> rfl

private abbrev Card11MacroTail4 := Fin 1 ⊕ Fin 3
private abbrev Card11MacroTail7 := Fin 3 ⊕ Card11MacroTail4
private abbrev Card11MacroTail8 := Fin 1 ⊕ Card11MacroTail7
private abbrev Card11MacroTail10 := Fin 2 ⊕ Card11MacroTail8

private def card11MacroTail4Equiv : Card11MacroTail4 ≃ Fin 4 :=
  finSumFinEquiv

private def card11MacroTail7Equiv : Card11MacroTail7 ≃ Fin 7 :=
  (Equiv.sumCongr (Equiv.refl (Fin 3)) card11MacroTail4Equiv).trans
    finSumFinEquiv

private def card11MacroTail8Equiv : Card11MacroTail8 ≃ Fin 8 :=
  (Equiv.sumCongr (Equiv.refl (Fin 1)) card11MacroTail7Equiv).trans
    finSumFinEquiv

private def card11MacroTail10Equiv : Card11MacroTail10 ≃ Fin 10 :=
  (Equiv.sumCongr (Equiv.refl (Fin 2)) card11MacroTail8Equiv).trans
    finSumFinEquiv

/-- Enumerate the six macro blocks consecutively. -/
def card11MacroPartToFin : Card11MacroPart ≃ Fin 11 :=
  (Equiv.sumCongr (Equiv.refl (Fin 1)) card11MacroTail10Equiv).trans
    finSumFinEquiv

/-- The only choices left after fixing the six macro blocks: an order on the
two `O2` labels and independent orders on the three `S` and three `O1`
labels. -/
abbrev Card11InternalOrder :=
  Equiv.Perm (Fin 2) × (Equiv.Perm (Fin 3) × Equiv.Perm (Fin 3))

/-- Apply an internal order independently inside the `O2`, `S`, and `O1`
blocks. -/
def card11InternalPartPerm
    (order : Card11InternalOrder) : Equiv.Perm Card11MacroPart :=
  Equiv.sumCongr (Equiv.refl (Fin 1))
    (Equiv.sumCongr order.1
      (Equiv.sumCongr (Equiv.refl (Fin 1))
        (Equiv.sumCongr order.2.1
          (Equiv.sumCongr (Equiv.refl (Fin 1)) order.2.2))))

/-- The label-to-boundary-position equivalence determined by an internal
order. -/
def card11IndexEquiv (order : Card11InternalOrder) : Fin 11 ≃ Fin 11 :=
  card11MacroSplit |>.trans (card11InternalPartPerm order) |>.trans
    card11MacroPartToFin

/-- Evaluation of the card-11 index equivalence on a surplus-interior label. -/
@[simp] theorem card11IndexEquiv_surplusInterior
    (order : Card11InternalOrder) (i : Fin 3) :
    card11IndexEquiv order ⟨3 + i, by omega⟩ =
      ⟨4 + order.2.1 i, by omega⟩ := by
  fin_cases i <;> apply Fin.ext <;>
    simp [card11IndexEquiv, card11MacroSplit, card11InternalPartPerm,
      card11MacroPartToFin, card11MacroTail10Equiv,
      card11MacroTail8Equiv, card11MacroTail7Equiv,
      card11MacroTail4Equiv, finSumFinEquiv] <;> omega

/-- Evaluation of the card-11 index equivalence on a first
non-surplus-cap interior label. -/
@[simp] theorem card11IndexEquiv_firstOtherInterior
    (order : Card11InternalOrder) (i : Fin 3) :
    card11IndexEquiv order ⟨6 + i, by omega⟩ =
      ⟨8 + order.2.2 i, by omega⟩ := by
  fin_cases i <;> apply Fin.ext <;>
    simp [card11IndexEquiv, card11MacroSplit, card11InternalPartPerm,
      card11MacroPartToFin, card11MacroTail10Equiv,
      card11MacroTail8Equiv, card11MacroTail7Equiv,
      card11MacroTail4Equiv, finSumFinEquiv] <;> omega

/-- Evaluation of the card-11 index equivalence on a second
non-surplus-cap interior label. -/
@[simp] theorem card11IndexEquiv_secondOtherInterior
    (order : Card11InternalOrder) (i : Fin 2) :
    card11IndexEquiv order ⟨9 + i, by omega⟩ =
      ⟨1 + order.1 i, by omega⟩ := by
  fin_cases i <;> apply Fin.ext <;>
    simp [card11IndexEquiv, card11MacroSplit, card11InternalPartPerm,
      card11MacroPartToFin, card11MacroTail10Equiv,
      card11MacroTail8Equiv, card11MacroTail7Equiv,
      card11MacroTail4Equiv, finSumFinEquiv]

/-- The direct finite surface of the `2! * 3! * 3!` internal orders. -/
def card11MacroOrders : Finset Card11InternalOrder := Finset.univ

@[simp] theorem mem_card11MacroOrders (order : Card11InternalOrder) :
    order ∈ card11MacroOrders := by
  simp [card11MacroOrders]

/-- The card-11 macro-order surface has exactly 72 elements. -/
theorem card_card11MacroOrders : card11MacroOrders.card = 72 := by
  norm_num [card11MacroOrders, Card11InternalOrder, Fintype.card_perm,
    Nat.factorial]

/-- A CCW boundary enumeration compatible with a card-11 realization and one
of the finite macro orders. -/
structure Card11MacroCcwLabeling (pointOf : Fin 11 → ℝ²) where
  order : Card11InternalOrder
  boundary : Fin 11 → ℝ²
  boundary_injective : Function.Injective boundary
  boundary_ccw : EuclideanGeometry.IsCcwConvexPolygon boundary
  point_eq : ∀ label, boundary (card11IndexEquiv order label) = pointOf label

/-- Every admissible card-11 macro order is rejected by some equality-closure
separation core of the row pattern. -/
def RejectsEveryCard11MacroOrder (P : RowPattern (Fin 11)) : Prop :=
  ∀ order ∈ card11MacroOrders,
    ∃ core : SharedPairSeparationCore P,
      ¬ core.SatisfiedBy (card11IndexEquiv order)

/-- A row pattern that rejects every macro order cannot be realized together
with a supplied compatible CCW macro labeling. -/
theorem false_of_rejectsEveryCard11MacroOrder
    {P : RowPattern (Fin 11)} {pointOf : Fin 11 → ℝ²}
    (hreject : RejectsEveryCard11MacroOrder P)
    (hreal : Realizes P pointOf) (L : Card11MacroCcwLabeling pointOf) : False := by
  rcases hreject L.order (mem_card11MacroOrders L.order) with
    ⟨core, hviolates⟩
  exact hviolates <|
    core.satisfiedBy_of_realizes_ccw hreal L.boundary
      (card11IndexEquiv L.order) L.boundary_ccw L.boundary_injective
      (card11IndexEquiv L.order).injective L.point_eq

/-- Existential form of `false_of_rejectsEveryCard11MacroOrder`. -/
theorem not_exists_realizes_with_card11MacroCcwLabeling
    {P : RowPattern (Fin 11)} (hreject : RejectsEveryCard11MacroOrder P) :
    ¬ ∃ pointOf : Fin 11 → ℝ²,
      Realizes P pointOf ∧ Nonempty (Card11MacroCcwLabeling pointOf) := by
  rintro ⟨pointOf, hreal, ⟨L⟩⟩
  exact false_of_rejectsEveryCard11MacroOrder hreject hreal L

end SeparationCore
end Census554
end Problem97
